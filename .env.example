# Prahari-NGO — Environment Variables (template)
# Copy to .env and fill in values

# ── GCP Project ──
PROJECT_ID=prahari-ngo-rj
REGION=asia-south1

# ── External APIs ──
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Dashboard (Firebase) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=prahari-ngo-rj
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Agent URLs (local dev) ──
NEXT_PUBLIC_INGESTOR_URL=http://localhost:8001
NEXT_PUBLIC_WATCHER_URL=http://localhost:8002
NEXT_PUBLIC_COORDINATOR_URL=http://localhost:8003

# ── Google Maps ──
NEXT_PUBLIC_MAPS_API_KEY=
